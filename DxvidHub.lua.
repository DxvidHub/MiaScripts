local function AplicarEstiloReal(instancia)
    if spoofEnabled and (instancia:IsA("TextLabel") or instancia:IsA("TextButton")) then
        local texto = instancia.Text
        if (string.find(texto, NombreReal) or string.find(texto, DisplayReal)) and not string.find(texto, "[MOD]") then
            instancia.RichText = true 
            instancia.Text = NombreMOD
        end
    end
end

